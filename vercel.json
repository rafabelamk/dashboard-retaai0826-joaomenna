{
  "version": 2,
  "name": "dashboard-retaai0726-joaomenna",
  "functions": {
    "api/meta.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/meta",
      "dest": "/api/meta.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
